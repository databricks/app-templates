# Databricks authentication
DATABRICKS_CONFIG_PROFILE=DEFAULT

# MLflow tracking
MLFLOW_TRACKING_URI=databricks://DEFAULT
MLFLOW_REGISTRY_URI=databricks-uc
MLFLOW_EXPERIMENT_ID=

# Agent model and AI Gateway
MODEL=databricks-claude-sonnet-4-6
AI_GATEWAY_URL=https://<workspace-id>.ai-gateway.cloud.databricks.com/anthropic

# Long-running Responses API server
TASK_TIMEOUT_SECONDS=3600
POLL_INTERVAL_SECONDS=1.0
LOG_LEVEL=INFO

# Lakebase. Use one mode:
# 1. Autoscaling endpoint, preferred for new templates.
LAKEBASE_AUTOSCALING_ENDPOINT=
PGDATABASE=databricks_postgres

# 2. Provisioned Lakebase instance.
# LAKEBASE_INSTANCE_NAME=
# PGDATABASE=databricks_postgres

# Chat UI
CHAT_APP_PORT=3000
CHAT_PROXY_TIMEOUT_SECONDS=300
