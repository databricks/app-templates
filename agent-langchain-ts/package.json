{
  "name": "@databricks/agent-langchain-ts",
  "version": "1.0.0",
  "description": "TypeScript LangChain agent on Databricks, powered by @databricks/appkit",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "predev": "bash scripts/setup-ui.sh",
    "dev": "concurrently --names \"agent,ui\" --prefix-colors \"blue,green\" \"npm run dev:agent\" \"npm run dev:ui\"",
    "dev:agent": "PORT=5001 tsx watch src/main.ts",
    "dev:ui": "cd ui && API_PROXY=http://localhost:5001/invocations CHAT_APP_PORT=3001 npm run dev",
    "start": "node $PWD/dist/src/main.js",
    "build": "bash scripts/setup-ui.sh && npm run build:agent && npm run build:ui",
    "build:agent": "tsc",
    "build:agent-only": "tsc",
    "build:ui": "cd ui && npm install && npm run build",
    "test": "jest --testPathIgnorePatterns=examples",
    "test:unit": "jest tests/agent.test.ts",
    "test:e2e": "jest --config jest.e2e.config.js",
    "test:all": "npm run test:unit",
    "link:appkit": "npm install --save ../../appkit/packages/appkit/tmp/databricks-appkit-*.tgz",
    "quickstart": "tsx scripts/quickstart.ts",
    "discover-tools": "tsx scripts/discover-tools.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@arizeai/openinference-instrumentation-langchain": "^4.0.0",
    "@databricks/appkit": "^0.16.0",
    "@databricks/langchainjs": "^0.1.0",
    "@langchain/core": "^1.1.8",
    "@langchain/langgraph": "^1.1.2",
    "@langchain/mcp-adapters": "^1.1.1",
    "dotenv": "^16.4.5",
    "mathjs": "^15.1.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "concurrently": "^9.2.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "databricks",
    "langchain",
    "appkit",
    "agent",
    "typescript"
  ],
  "author": "Databricks",
  "license": "Apache-2.0"
}
