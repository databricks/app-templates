DATABRICKS_HOST=https://...

# Comma-separated alias=spaceId pairs configured at server boot.
# Example: GENIE_SPACES=sales=01ABC...,support=01DEF...
# If unset, falls back to DATABRICKS_GENIE_SPACE_ID under the `default` alias.
GENIE_SPACES=
DATABRICKS_GENIE_SPACE_ID=your_genie_space_id

DATABRICKS_APP_PORT=8000
DATABRICKS_APP_NAME=appkit-genie-advanced
FLASK_RUN_HOST=0.0.0.0
